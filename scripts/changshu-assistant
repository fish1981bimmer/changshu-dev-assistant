#!/usr/bin/env bash
# changshu-assistant 启动脚本

# 获取脚本所在目录
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
SCRIPT_PATH="$SCRIPT_DIR/changshu-assistant.py"

# 检查脚本是否存在
if [ ! -f "$SCRIPT_PATH" ]; then
    echo "错误: 未找到 changshu-assistant.py 脚本"
    echo "请确保脚本位于: $SCRIPT_PATH"
    exit 1
fi

# 执行脚本
python3 "$SCRIPT_PATH" "$@"