{
  "name": "model_selection",
  "version": "1.0.0",
  "description": "AI模型选择策略",
  "author": "Hermes Agent",
  "models": {
    "openrouter": {
      "api_base": "https://openrouter.ai/api/v1",
      "models": {
        "gemma-7b-it": {
          "type": "lightweight",
          "capabilities": ["general", "code"],
          "max_tokens": 8192
        },
        "mistral-7b": {
          "type": "lightweight",
          "capabilities": ["general"],
          "max_tokens": 8192
        }
      }
    },
    "nvidia": {
      "api_base": "https://integrate.api.nvidia.com/v1",
      "models": {
        "llama2-70b": {
          "type": "heavy",
          "capabilities": ["general", "code", "analysis"],
          "max_tokens": 4096
        },
        "yi-34b": {
          "type": "heavy",
          "capabilities": ["general", "code", "analysis"],
          "max_tokens": 4096
        }
      }
    }
  },
  "task_classification": {
    "lightweight_tasks": [
      "simple_query",
      "code_explanation",
      "documentation",
      "translation"
    ],
    "heavy_tasks": [
      "code_generation",
      "complex_analysis",
      "system_design",
      "troubleshooting"
    ],
    "code_tasks": [
      "code_review",
      "debugging",
      "refactoring",
      "implementation"
    ]
  }
}